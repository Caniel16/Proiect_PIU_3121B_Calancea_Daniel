<Window x:Class="MediaTracker_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaTracker" Height="650" Width="900"
        Background="#1A1A2E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- MENIU -->
        <Menu Grid.Row="0" Background="#0F1628" Foreground="White">
            <MenuItem Header="Library" Foreground="White" Background="#0F1628">
                <MenuItem x:Name="MenuAdd" Header="Add File" Click="MenuAdd_Click"/>
                <MenuItem x:Name="MenuSearch" Header="Search" Click="MenuSearch_Click"/>
                <Separator/>
                <MenuItem x:Name="MenuExit" Header="Exit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="Player" Foreground="White" Background="#0F1628">
                <MenuItem x:Name="MenuLoad" Header="Load Library" Click="LoadButton_Click"/>
            </MenuItem>
            <MenuItem Header="Help" Foreground="White" Background="#0F1628">
                <MenuItem x:Name="MenuAbout" Header="About" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- TITLU -->
        <TextBlock Grid.Row="1" Text="MediaTracker" FontSize="24" FontWeight="Bold"
                   Foreground="#E94560" HorizontalAlignment="Center"
                   Margin="0,16,0,16"/>

        <!-- CONTINUT PRINCIPAL -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- COLOANA STANGA - Formular adaugare -->
            <StackPanel Grid.Column="0" x:Name="AddPanel">

                <TextBlock Text="Add File" Foreground="#E94560"
                           FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

                <!-- Title -->
                <TextBlock x:Name="TitleLabel" Text="Title:" Foreground="White" FontSize="13"/>
                <TextBox x:Name="TitleInput" Margin="0,4,0,4"
                         Background="#16213E" Foreground="White"
                         BorderBrush="#0F3460" Padding="8,6" FontSize="13"/>
                <TextBlock x:Name="TitleError" Foreground="#E94560" FontSize="11"
                           Margin="0,0,0,10" Visibility="Collapsed"/>

                <!-- Path -->
                <TextBlock x:Name="PathLabel" Text="Path:" Foreground="White" FontSize="13"/>
                <TextBox x:Name="PathInput" Margin="0,4,0,4"
                         Background="#16213E" Foreground="White"
                         BorderBrush="#0F3460" Padding="8,6" FontSize="13"/>
                <TextBlock x:Name="PathError" Foreground="#E94560" FontSize="11"
                           Margin="0,0,0,10" Visibility="Collapsed"/>

                <!-- Gen - RadioButtons -->
                <TextBlock x:Name="GenLabel" Text="Genre:" Foreground="White"
                           FontSize="13" Margin="0,0,0,6"/>
                <WrapPanel x:Name="GenPanel" Margin="0,0,0,4">
                    <RadioButton x:Name="RadioFantezie" Content="Fantezie"
                                 Foreground="White" Margin="0,0,12,6"
                                 GroupName="Gen"/>
                    <RadioButton x:Name="RadioSciFi" Content="ScientificFiction"
                                 Foreground="White" Margin="0,0,12,6"
                                 GroupName="Gen"/>
                    <RadioButton x:Name="RadioMister" Content="Mister"
                                 Foreground="White" Margin="0,0,12,6"
                                 GroupName="Gen"/>
                    <RadioButton x:Name="RadioRomance" Content="Romance"
                                 Foreground="White" Margin="0,0,12,6"
                                 GroupName="Gen"/>
                    <RadioButton x:Name="RadioNonFictiune" Content="NonFictiune"
                                 Foreground="White" Margin="0,0,12,6"
                                 GroupName="Gen"/>
                </WrapPanel>
                <TextBlock x:Name="GenError" Foreground="#E94560" FontSize="11"
                           Margin="0,0,0,10" Visibility="Collapsed"/>

                <!-- Stare - CheckBoxes -->
                <TextBlock Text="State:" Foreground="White"
                           FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Margin="0,0,0,16">
                    <CheckBox x:Name="CheckAscultat" Content="Ascultat"
                              Foreground="White" Margin="0,0,0,4"/>
                    <CheckBox x:Name="CheckFavorit" Content="Favorit"
                              Foreground="White" Margin="0,0,0,4"/>
                    <CheckBox x:Name="CheckDeAscultat" Content="DeAscultat"
                              Foreground="White" Margin="0,0,0,4"/>
                    <CheckBox x:Name="CheckArhivat" Content="Arhivat"
                              Foreground="White" Margin="0,0,0,4"/>
                </StackPanel>

                <!-- Butoane -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="AddButton" Content="Add File"
                            Click="AddButton_Click"
                            Background="#E94560" Foreground="White"
                            BorderThickness="0" Padding="16,8"
                            FontSize="13" Cursor="Hand" Margin="0,0,10,0"/>
                    <Button x:Name="ClearButton" Content="Clear"
                            Click="ClearButton_Click"
                            Background="#0F3460" Foreground="White"
                            BorderThickness="0" Padding="16,8"
                            FontSize="13" Cursor="Hand"/>
                </StackPanel>

                <TextBlock x:Name="SuccessText" Foreground="#4CAF50" FontSize="13"
                           Margin="0,12,0,0" Visibility="Collapsed"/>
            </StackPanel>

            <!-- COLOANA DREAPTA - Cautare + Detalii -->
            <StackPanel Grid.Column="2" x:Name="SearchPanel">

                <TextBlock Text="Search" Foreground="#E94560"
                           FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>

                <!-- Cautare -->
                <TextBlock Text="Search by title:" Foreground="White" FontSize="13"/>
                <Grid Margin="0,4,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchInput" Grid.Column="0"
                             Background="#16213E" Foreground="White"
                             BorderBrush="#0F3460" Padding="8,6" FontSize="13"/>
                    <Button Grid.Column="1" Content="Search"
                            Click="SearchButton_Click"
                            Background="#E94560" Foreground="White"
                            BorderThickness="0" Padding="12,6"
                            FontSize="13" Cursor="Hand" Margin="8,0,0,0"/>
                </Grid>

                <TextBlock x:Name="SearchError" Foreground="#E94560" FontSize="11"
                           Margin="0,0,0,10" Visibility="Collapsed"/>

                <!-- Detalii fisier gasit -->
                <StackPanel x:Name="DetailsPanel" Visibility="Collapsed">
                    <TextBlock Text="File found:" Foreground="White"
                               FontSize="13" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Title:" Foreground="#8892B0" FontSize="13"/>
                        <TextBlock x:Name="TitleText" Grid.Column="1"
                                   Foreground="White" FontSize="13"
                                   FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Path:" Foreground="#8892B0" FontSize="13"/>
                        <TextBlock x:Name="PathText" Grid.Column="1"
                                   Foreground="White" FontSize="13"
                                   TextWrapping="Wrap"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Position:" Foreground="#8892B0" FontSize="13"/>
                        <TextBlock x:Name="PositionText" Grid.Column="1"
                                   Foreground="White" FontSize="13"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Genre:" Foreground="#8892B0" FontSize="13"/>
                        <TextBlock x:Name="GenreText" Grid.Column="1"
                                   Foreground="White" FontSize="13"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="State:" Foreground="#8892B0" FontSize="13"/>
                        <TextBlock x:Name="StateText" Grid.Column="1"
                                   Foreground="White" FontSize="13"/>
                    </Grid>
                </StackPanel>

                <TextBlock x:Name="NotFoundText" Foreground="#E94560" FontSize="13"
                           Margin="0,8,0,0" Visibility="Collapsed"
                           Text="No file found with that title."/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>