<Window x:Class="MediaTracker_UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaTracker" Height="400" Width="500"
        Background="#1A1A2E">

    <StackPanel Margin="30">

        <TextBlock Text="MediaTracker" FontSize="24" FontWeight="Bold"
                   Foreground="#E94560" HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <TextBlock Text="Title:" Foreground="White" FontSize="13"/>
        <TextBlock x:Name="TitleText" Foreground="#8892B0" FontSize="16"
                   FontWeight="SemiBold" Margin="0,2,0,12"/>

        <TextBlock Text="Path:" Foreground="White" FontSize="13"/>
        <TextBlock x:Name="PathText" Foreground="#8892B0" FontSize="13"
                   Margin="0,2,0,12" TextWrapping="Wrap"/>

        <TextBlock Text="Saved Position:" Foreground="White" FontSize="13"/>
        <TextBlock x:Name="PositionText" Foreground="#8892B0" FontSize="13"
                   Margin="0,2,0,12"/>

        <TextBlock Text="Genre:" Foreground="White" FontSize="13"/>
        <TextBlock x:Name="GenreText" Foreground="#8892B0" FontSize="13"
                   Margin="0,2,0,12"/>

        <TextBlock Text="State:" Foreground="White" FontSize="13"/>
        <TextBlock x:Name="StateText" Foreground="#8892B0" FontSize="13"
                   Margin="0,2,0,20"/>

        <Button x:Name="LoadButton" Content="Load from library"
                Click="LoadButton_Click"
                Background="#E94560" Foreground="White"
                BorderThickness="0" Padding="12,8"
                FontSize="13" Cursor="Hand"/>
    </StackPanel>
</Window>